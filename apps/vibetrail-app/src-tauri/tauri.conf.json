{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeTrail",
  "version": "0.2.0",
  "identifier": "dev.vibetrail.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VibeTrail",
        "width": 1240,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
